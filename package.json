{
  "name": "@skxv/oct-daemon",
  "version": "0.1.0",
  "description": "Headless host daemon for Open Collaboration Tools",
  "type": "module",
  "bin": {
    "oct-daemon": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx src/cli.ts",
    "prepack": "pnpm clean && pnpm build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "minimatch": "^10.1.1",
    "open-collaboration-protocol": "^0.3.1",
    "open-collaboration-yjs": "^0.3.1",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@9.15.9"
}
